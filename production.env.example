# Koffy production configuration.
# Copy to production.env, replace every replace-me value, and keep it out of Git.

# Immutable application images published by your build pipeline.
KOFFY_WEB_IMAGE=ghcr.io/example/koffy-web:v0.1.0
KOFFY_BILLING_API_IMAGE=ghcr.io/example/koffy-billing-api:v0.1.0
KOFFY_GATEWAY_IMAGE=ghcr.io/example/koffy-gateway:v0.1.0

# Infrastructure images. Pin tested versions before a controlled rollout.
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:8.4-alpine
CASDOOR_IMAGE=casbin/casdoor:3.60.2
NGINX_IMAGE=nginx:1.27-alpine
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest

# Host-side configuration files. Copy each tracked .example file first.
KOFFY_NGINX_CONFIG=./deployments/nginx/koffy.conf
KOFFY_CERTS_DIR=./certs
LITELLM_CONFIG_FILE=./deployments/litellm/config.yaml
KOFFY_DOCKER_NETWORK=koffy

# Runtime mode and logging.
APP_ENV=production
LOG_LEVEL=info

# Public HTTPS endpoints visible to browsers and client applications.
PUBLIC_WEB_URL=https://koffy.example.com
PUBLIC_GATEWAY_URL=https://gateway.koffy.example.com
PUBLIC_CASDOOR_URL=https://auth.koffy.example.com

# MySQL. MYSQL_ROOT_PASSWORD is used only by the MySQL container; Koffy receives
# only the lower-privilege application account below.
MYSQL_ROOT_PASSWORD=replace-me-with-a-random-root-password
MYSQL_DATABASE=koffy
MYSQL_USER=koffy_user
MYSQL_PASSWORD=replace-me-with-a-random-application-password

# Redis sessions, rate limits, and append-only persistence.
REDIS_PASSWORD=replace-me-with-a-random-redis-password
REDIS_DB=0

# Casdoor configuration created by you after its first startup.
CASDOOR_CLIENT_ID=replace-me
CASDOOR_CLIENT_SECRET=replace-me
# Keep literal \n escapes inside the quoted certificate value.
CASDOOR_CERTIFICATE="-----BEGIN CERTIFICATE-----\nREPLACE_WITH_CASDOOR_APPLICATION_CERTIFICATE\n-----END CERTIFICATE-----"
CASDOOR_ORGANIZATION_NAME=koffy
CASDOOR_APPLICATION_NAME=koffy-production
# Optional Casdoor SMS provider name. Required for phone verification flows.
REGISTRATION_SMS_PROVIDER=
# Comma-separated business application origins allowed in return_to.
AUTH_ALLOWED_RETURN_ORIGINS=https://app.example.com

# Human verification protects SMS sending only; SMS codes remain enabled when false.
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=none
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=
# Required only for CAPTCHA_ENABLED=true and CAPTCHA_PROVIDER=tencent.
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET_KEY=

# Optional WeChat login. Official account handles in-WeChat login; website app
# handles desktop QR login.
WECHAT_OFFICIAL_APP_ID=
WECHAT_OFFICIAL_APP_SECRET=
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=

# Internal service settings.
BILLING_INTERNAL_API_KEY=replace-me-with-at-least-32-random-bytes
COIN_EXCHANGE_RATE_CNY=100
ENTITLEMENT_MAINTENANCE_INTERVAL_MINUTES=60
LITELLM_MASTER_KEY=replace-me-with-a-random-litellm-master-key
AI_GATEWAY_DEFAULT_PREAUTH_TOKENS=2000
AI_GATEWAY_APP_RATE_LIMIT_PER_MINUTE=600
AI_GATEWAY_USER_RATE_LIMIT_PER_MINUTE=120

# Model-provider credential consumed by your LiteLLM config.
OPENAI_API_KEY=replace-me

# Optional WeChat Pay. Leave disabled until all merchant settings and files exist.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MCH_CERT_SERIAL_NO=
# Paths inside koffy-billing-api. Host files live under ./secrets.
WECHAT_PAY_PRIVATE_KEY_PATH=/app/secrets/wechat_pay_private_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEY_PATH=/app/secrets/wechat_pay_public_key.pem
WECHAT_PAY_NOTIFY_URL=https://koffy.example.com/api/v1/payments/wechat/notify
