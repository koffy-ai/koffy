# Koffy local development configuration.
# Copy this file to .env. Never commit .env.

# Runtime mode: local enables X-User-ID for gateway development requests.
APP_ENV=local
# Application log verbosity: debug, info, warn, or error.
LOG_LEVEL=debug

# Browser-facing Koffy Web URL.
PUBLIC_WEB_URL=http://localhost:3000
# Browser-facing Koffy Gateway URL.
PUBLIC_GATEWAY_URL=http://localhost:8081
# Browser-facing URL of your Casdoor deployment.
PUBLIC_CASDOOR_URL=http://localhost:8000

# MySQL connection used by Koffy. The local Compose service is named mysql.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=koffy
MYSQL_USER=koffy_user
# Local-only placeholder. Replace it if the environment is reachable by others.
MYSQL_PASSWORD=local-koffy-password
# Used only by the local MySQL container and initial database creation.
MYSQL_ROOT_PASSWORD=local-root-password

# Redis connection used for sessions and rate limits.
REDIS_ADDR=redis:6379
# Leave empty when the local Redis container has no password.
REDIS_PASSWORD=
# Redis logical database number.
REDIS_DB=0

# Internal URL reachable from the Koffy Billing API container.
CASDOOR_ENDPOINT=http://casdoor:8000
# REQUIRED for login: values from your Casdoor application.
CASDOOR_CLIENT_ID=replace-with-casdoor-client-id
CASDOOR_CLIENT_SECRET=replace-with-casdoor-client-secret
# REQUIRED for JWT verification. Keep literal \n escapes inside the quoted value.
CASDOOR_CERTIFICATE="-----BEGIN CERTIFICATE-----\nREPLACE_WITH_CASDOOR_APPLICATION_CERTIFICATE\n-----END CERTIFICATE-----"
# REQUIRED: Casdoor organization and application names created by you.
CASDOOR_ORGANIZATION_NAME=koffy
CASDOOR_APPLICATION_NAME=koffy-local
# Optional Casdoor SMS provider name used for phone verification.
REGISTRATION_SMS_PROVIDER=
# Comma-separated external origins allowed in login return_to. Local paths are always allowed.
AUTH_ALLOWED_RETURN_ORIGINS=http://localhost:5173,https://app.example.com

# Human verification protects SMS sending only; it does not disable SMS verification itself.
CAPTCHA_ENABLED=false
# Supported values: none or tencent.
CAPTCHA_PROVIDER=none
# Generic provider fields reserved for compatible implementations.
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=
# Tencent Cloud API credentials and CAPTCHA application settings.
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET_KEY=

# Optional WeChat login credentials. Official account is used inside WeChat;
# website application is used by desktop QR login.
WECHAT_OFFICIAL_APP_ID=
WECHAT_OFFICIAL_APP_SECRET=
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=

# Billing API listener and internal URL.
BILLING_API_ADDR=:8080
BILLING_API_URL=http://koffy-billing-api:8080
# Shared secret used only between Koffy Gateway and Billing API.
BILLING_INTERNAL_API_KEY=local-internal-api-key
# Points credited per CNY yuan.
COIN_EXCHANGE_RATE_CNY=100
# Background entitlement maintenance interval in minutes.
ENTITLEMENT_MAINTENANCE_INTERVAL_MINUTES=60

# Gateway listener and downstream LiteLLM endpoint.
AI_GATEWAY_ADDR=:8081
# LiteLLM container image used by local Compose. Pin a tested tag when reproducibility matters.
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
LITELLM_BASE_URL=http://litellm:4000
# Must match the LiteLLM master key.
LITELLM_MASTER_KEY=local-litellm-master-key
# Default token estimate reserved before a chat request.
AI_GATEWAY_DEFAULT_PREAUTH_TOKENS=2000
# In-memory request limits per application and per user.
AI_GATEWAY_APP_RATE_LIMIT_PER_MINUTE=600
AI_GATEWAY_USER_RATE_LIMIT_PER_MINUTE=120

# Model provider credential consumed by the sample LiteLLM configuration.
OPENAI_API_KEY=replace-with-openai-api-key

# Optional WeChat Pay integration. Keep disabled until every required field is set.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
# 32-character API v3 key from the WeChat Pay merchant platform.
WECHAT_PAY_API_V3_KEY=
# Merchant API certificate serial number.
WECHAT_PAY_MCH_CERT_SERIAL_NO=
# Paths inside koffy-billing-api; mount files through Compose in production.
WECHAT_PAY_PRIVATE_KEY_PATH=/app/secrets/wechat_pay_private_key.pem
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEY_PATH=/app/secrets/wechat_pay_public_key.pem
# Public HTTPS callback without query parameters.
WECHAT_PAY_NOTIFY_URL=https://koffy.example.com/api/v1/payments/wechat/notify
